{
  "name": "speech-to-scene",
  "version": "0.0.0",
  "description": "Local-first, human-in-the-loop visual asset planning for talking-head videos.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.7.0",
  "bin": {
    "s2s": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:all": "pnpm build && pnpm web:build",
    "start": "pnpm build:all && node dist/cli/index.js review ./workspace/default",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"tests/**/*.tsx\" \"web/**/*.ts\" \"web/**/*.tsx\" \"web/**/*.css\" \"docs/**/*.md\" \".github/**/*.yml\" \"catalog/**/*.yaml\" \"*.{json,js,md,yaml}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"tests/**/*.tsx\" \"web/**/*.ts\" \"web/**/*.tsx\" \"web/**/*.css\" \"docs/**/*.md\" \".github/**/*.yml\" \"catalog/**/*.yaml\" \"*.{json,js,md,yaml}\"",
    "lint": "eslint .",
    "s2s": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:dist-smoke": "pnpm build && vitest run tests/unit/dist-smoke-project.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json && tsc -p web/tsconfig.json",
    "web:build": "vite build --config web/vite.config.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:preview": "vite preview --config web/vite.config.ts",
    "dev:server": "tsx src/cli/index.ts review ./workspace/default --no-open",
    "dev:web": "vite --config web/vite.config.ts",
    "dev": "tsx src/cli/index.ts review ./workspace/default --no-open & vite --config web/vite.config.ts"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "29.1.1",
    "lucide-react": "1.24.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "8.1.4",
    "vitest": "^4.1.10"
  }
}
